{
  "manifest_version":3,
  "name":"Background Editor",
  "version":"1.0",
  "description":"Edit webpage backgrounds.",
  "icons":{
    "32":"icons/icon32.png"
  },
  "action":{
    "default_popup":"popup.html",
    "default_icon":"icons/icon32.png"
  },
  "permissions":[
    "activeTab",
    "scripting"
  ],
  "host_permissions":[
    "<all_urls>"
  ],
  "content_scripts":[
    {
      "matches":[
        "<all_urls>"
      ],
      "js":[
        "content.js"
      ]
    }
  ]
}
